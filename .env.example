SECRET_KEY=your-super-secret-key-here
JWT_SECRET_KEY=your-jwt-secret-key-here
DATABASE_URL=sqlite:///auth.db




#!/bin/bash
set -e

echo "Frontend Entrypoint - Starting..."
echo "Container ID: $(hostname)"

# Define Paths
SOURCE_DIR="/app/frontend"
LOCAL_DIR="/tmp/frontend-build"
# BACKEND_HOST=$(echo ${NEXT_PUBLIC_API_URL} | sed -E 's#http://([^:]+):.*#\1#')
# BACKEND_PORT=$(echo ${NEXT_PUBLIC_API_URL} | sed -E 's#http://.*:([0-9]+)#\1#')
BACKEND_HOST="backend"
BACKEND_PORT="8000"

# Copy source code to local temporary directory (each container gets its own copy)
echo "Copying source code to local directory..."
rm -rf $LOCAL_DIR
mkdir -p $LOCAL_DIR
cp -r $SOURCE_DIR/* $LOCAL_DIR/
cd $LOCAL_DIR
rm -rf node_modules

echo "Working in: $(pwd)"
echo "Project structure:"
ls -la

# Verify Next.js project structure
if [ ! -f "package.json" ]; then
  echo "ERROR: package.json not found!"
  exit 1
fi

if [ ! -f "next.config.js" ] && [ ! -f "next.config.mjs" ] && [ ! -f "next.config.ts" ]; then
  echo "WARNING: No next.config found, using defaults"
fi

# Install dependencies locally
echo "Installing dependencies in local directory..."
npm config set //artifactory.cib.echonet/artifactory/api/npm/global-npm-dev/:_authToken 
npm install --legacy-peer-deps

# ============================================================
# SHARED BUILD ID - ensures all 3 replicas produce identical chunks
# Uses flock for atomic first-writer-wins across simultaneous replicas.
# The .build-id file lives on the shared bind mount (/app/frontend)
# so all replicas see the same value. deploy.sh should remove it
# before each stack deploy to generate a fresh ID per deployment.
# ============================================================
BUILD_ID_FILE="/app/frontend/.build-id"
BUILD_ID_LOCK="/app/frontend/.build-id.lock"

echo "Acquiring lock to read/write shared BUILD_ID..."
(
  flock -x 200
  if [ ! -f "$BUILD_ID_FILE" ] || [ ! -s "$BUILD_ID_FILE" ]; then
    NEW_ID="build-$(date +%Y%m%d-%H%M%S)"
    echo "$NEW_ID" > "$BUILD_ID_FILE"
    echo "  -> Generated new BUILD_ID: $NEW_ID (this replica is first)"
  else
    echo "  -> Reusing existing BUILD_ID: $(cat $BUILD_ID_FILE)"
  fi
) 200>"$BUILD_ID_LOCK"

export BUILD_ID=$(cat "$BUILD_ID_FILE")
echo "BUILD_ID for this replica: $BUILD_ID"
# ============================================================

# Build the application locally
echo "Building Next.js application in local directory..."
echo "This will process:"
echo "  - next.config.js (Next.js config)"
echo "  - tailwind.config.ts (Tailwind CSS)"
echo "  - postcss.config.js (PostCSS)"
echo "  - tsconfig.json (TypeScript)"
NODE_OPTIONS="--max-old-space-size=2048" npm run build

# Verify build output
if [ -d ".next" ]; then
  echo "✓ Build successful! .next directory created"
  ls -la .next/
else
  echo "ERROR: .next directory not created!"
  exit 1
fi

# ============================================================
# CHUNK ARCHIVE - preserves old chunks across deployments
# Users with open tabs during deploy won't hit 404 on old chunks.
# Archive lives on shared mount so all replicas contribute/read.
# Hashed filenames guarantee cp -n never overwrites anything.
# Old files pruned after 7 days to keep disk usage bounded.
# ============================================================
CHUNK_ARCHIVE="/app/frontend/.chunk-archive"
LOCAL_STATIC="$LOCAL_DIR/.next/static"

echo "Syncing chunks with shared archive at $CHUNK_ARCHIVE..."
mkdir -p "$CHUNK_ARCHIVE"

# Add this build's static files to the archive (never overwrites — hashed names)
cp -rn "$LOCAL_STATIC"/. "$CHUNK_ARCHIVE"/ 2>/dev/null || true

# Merge archive back into local build so this replica can also serve
# chunks from previous builds (covers users mid-session during deploy)
cp -rn "$CHUNK_ARCHIVE"/. "$LOCAL_STATIC"/ 2>/dev/null || true

# Prune files older than 7 days to keep archive size bounded
find "$CHUNK_ARCHIVE" -type f -mtime +7 -delete 2>/dev/null || true
find "$CHUNK_ARCHIVE" -type d -empty -delete 2>/dev/null || true

ARCHIVE_COUNT=$(find "$CHUNK_ARCHIVE" -type f 2>/dev/null | wc -l)
echo "✓ Chunk archive synced ($ARCHIVE_COUNT files retained)"
# ============================================================

# Wait for backend to be ready
echo "Waiting for backend..."
for i in {1..20}; do
  if curl -f http://${BACKEND_HOST}:${BACKEND_PORT}/api/health/ 2>/dev/null; then
    echo "Backend is ready!"
    break
  fi
  echo "Backend not ready yet (attempt $i/20)..."
  sleep 5
done

# Start the application
echo "Starting Next.js server from local build..."
exec npm run start






/**@type {import('next').NextConfig}*/
const nextConfig = {
    output: 'standalone',
    reactStrictMode: true,

    // Ensures all replicas produce byte-identical chunks by pinning the
    // build ID from the BUILD_ID env var (set by frontend-entrypoint.sh).
    // If BUILD_ID is missing for any reason, falls back to a stable string
    // so the build never breaks — but all replicas should always have it.
    generateBuildId: async () => {
        return process.env.BUILD_ID || 'qdi-portal-stable';
    },

    typescript: {
        ignoreBuildErrors: false,
    },

    eslint: {
        ignoreDuringBuilds: false,
    },

    trailingSlash: false,
    async headers() {
        return [{
            source: '/_next/static/chunks/:path*',
            headers: [
                { key: 'Cache-Control', value: 'public, max-age=31536000, immutable' },
            ],
        }, ];
    },
};

module.exports = nextConfig;
